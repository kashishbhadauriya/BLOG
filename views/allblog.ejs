<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>All Blog Posts</title>

  <!-- Bootstrap & FontAwesome -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
  <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #f1f4f9;
    }

    h2 {
      color: #333;
      font-weight: 600;
    }

    .blog-card {
      background: #fff;
      border: none;
      border-radius: 15px;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
    }

    .blog-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
    }

    .card-img-top {
      height: 220px;
      object-fit: cover;
    }

    .card-title {
      font-size: 1.2rem;
      color: #222;
      font-weight: 600;
    }

    .card-text {
      font-size: 0.95rem;
      color: #666;
    }

    .text-muted {
      font-size: 0.875rem;
      color: #888 !important;
    }

    .btn-outline-primary {
      color: #0d6efd;
      border-color: #0d6efd;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 6px 12px;
      transition: all 0.2s ease;
    }

    .btn-outline-primary:hover {
      background-color: #0d6efd;
      color: #fff;
    }

    /* Force 5 columns in a row on large screens */
    @media (min-width: 1200px) {
      .custom-col-5 {
        flex: 0 0 20%;
        max-width: 20%;
      }
    }

    .welcome-text {
      font-weight: 500;
      font-size: 1rem;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <%- include('./partials/nav') %>

  <div style="margin-top: 80px;"></div>

  <div class="container my-5">
    <h2 class="mb-4 text-center" data-aos="fade-down">All Blog Posts</h2>

    <% if (user) { %>
      <p class="text-end welcome-text" data-aos="fade-left">
        Welcome, <strong><%= user.FullName %></strong>
      </p>
    <% } %>

    <% if (blogs.length === 0) { %>
      <div class="alert alert-info text-center" data-aos="zoom-in">
        No blogs available.
      </div>
    <% } else { %>
      <div class="row g-4">
        <% blogs.forEach((blog, index) => { %>
          <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-5th" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="card blog-card h-100">
              <% if (blog.coverImageURL) { %>
                <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="Blog Cover">
              <% } %>
              <div class="card-body d-flex flex-column">
                <h5 class="card-title"><%= blog.title %></h5>
                <p class="card-text">
                  <%= blog.body.length > 120 ? blog.body.substring(0, 120) + '...' : blog.body %>
                </p>
                <p class="text-muted mt-auto">
                  By <%= blog.createdBy ? blog.createdBy.FullName : "Unknown" %> 
                  on <%= new Date(blog.createdAt).toLocaleDateString() %>
                </p>
                <div class="d-flex justify-content-between">
                  <a href="/blog/<%= blog._id %>#comments" 
                     class="btn btn-outline-primary btn-sm d-flex align-items-center gap-1">
                    <i class="fa fa-comment"></i> Comment
                  </a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
  <script>
    AOS.init({ once: true, duration: 800 });
  </script>

</body>
</html>
