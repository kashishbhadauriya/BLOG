<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Blog Posts</title>

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

  <style>
    body {
      background: #f3f4f6;
      font-family: 'Poppins', sans-serif;
    }

    h2 {
      color: #0d6efd;
      font-weight: 600;
    }

    .blog-card {
      border: none;
      border-radius: 16px;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      background: linear-gradient(to bottom, #ffffff, #f9f9f9);
    }

    .blog-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    }

    .card-img-top {
      height: 200px;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .card-img-top:hover {
      transform: scale(1.04);
    }

    .card-title {
      color: #222;
      font-size: 1.25rem;
      font-weight: 600;
    }

    .card-text {
      color: #444;
      font-size: 0.95rem;
    }

    .text-muted {
      font-size: 0.8rem;
    }

    .btn-outline-primary {
      border-color: #0d6efd;
      color: #0d6efd;
      font-weight: 500;
      transition: all 0.3s ease;
    }

    .btn-outline-primary:hover {
      background-color: #0d6efd;
      color: #fff;
    }

    .navbar-brand {
      font-weight: 600;
    }

    @media (min-width: 1200px) {
      .col-xl-5th {
        flex: 0 0 20%;
        max-width: 20%;
      }
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-white fixed-top shadow-sm">
    <div class="container-fluid">
      <a class="navbar-brand text-primary" href="/">Blogify</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNavDropdown">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link active" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/blog/allblog">All Blogs</a></li>

          <% if (user) { %>
            
            <li class="nav-item"><a class="nav-link" href="/blog/myblog">My Blogs</a></li>
            <li class="nav-item"><a class="nav-link" href="/blog/add-new">Add Blog</a></li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                <%= user.name || user.FullName %>
              </a>
             <ul class="dropdown-menu" style="left: -40px;">
  <li><a class="dropdown-item" href="/user/logout">Logout</a></li>
</ul>

            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/user/signin">Sign In</a></li>
            <li class="nav-item"><a class="nav-link" href="/user/signup">Create Account</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div style="margin-top: 80px;"></div>

  <!-- Alert -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger text-center container" role="alert">
      <%= error %>
    </div>
  <% } %>

  <!-- Blog Cards -->
  <div class="container my-5">
    <h2 class="mb-4 text-center" data-aos="fade-down">My Blog Posts</h2>

    <% if (user) { %>
      <p class="text-end" data-aos="fade-left">Welcome, <strong><%= user.fullname %></strong></p>
    <% } %>

    <% if (blogs.length === 0) { %>
      <div class="alert alert-info text-center" data-aos="zoom-in">You haven't posted any blogs yet.</div>
    <% } else { %>
      <div class="row g-4">
        <% blogs.forEach((blog, index) => { %>
          <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-5th" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="card blog-card h-100 shadow-sm">
              <% if (blog.coverImageURL) { %>
                <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="Cover Image">
              <% } %>
              <div class="card-body d-flex flex-column">
                <h5 class="card-title"><%= blog.title %></h5>
                <p class="card-text mb-2"><%= blog.body.length > 120 ? blog.body.substring(0, 120) + '...' : blog.body %></p>
                <p class="text-muted mb-3">Created on <%= new Date(blog.createdAt).toLocaleString() %></p>

                <div class="mt-auto">
                  <a href="/blog/<%= blog._id %>#comments"
                     class="btn btn-outline-primary btn-sm w-100 d-flex justify-content-center align-items-center gap-2">
                    <i class="fa fa-comment-dots"></i> Comment
                  </a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
  <script>
    AOS.init({ once: true, duration: 800 });
  </script>
</body>
</html>
